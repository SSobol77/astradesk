# ==============================================================================
# AstraDesk Environment Configuration (.env.example)
#
# Skopiuj ten plik do `.env` i uzupełnij wartości dla swojego środowiska.
# Ten plik zawiera konfigurację dla obu trybów deweloperskich:
# 1. Pełne środowisko Docker Compose.
# 2. Środowisko hybrydowe (Python lokalnie + zależności w Dockerze).
# ==============================================================================


# ------------------------------------------------------------------------------
# A. Konfiguracja Rdzennych Serwisów (Core Services)
# ------------------------------------------------------------------------------
# Te zmienne definiują, jak poszczególne komponenty AstraDesk łączą się ze sobą.

# --- A.1. Baza Danych PostgreSQL (dla RAG, dialogów, audytów) ---
# Wybierz jedną z opcji, w zależności od trybu pracy.

# Opcja dla środowiska hybrydowego (Python lokalnie) LUB połączenia z bazą w chmurze (np. Neon)
DATABASE_URL=postgresql://neondb_owner:your_password@your_neon_host/neondb?sslmode=require

# Opcja dla pełnego środowiska Docker Compose (używa wewnętrznej nazwy serwisu `db`)
# DATABASE_URL=postgresql://astradesk:astrapass@db:5432/astradesk


# --- A.2. Baza Danych MySQL (dla Java Ticket Adapter) ---
# Używane przez `ticket-adapter-java` do przechowywania ticketów.

# Opcja dla środowiska hybrydowego (Java lokalnie)
MYSQL_URL_R2DBC=r2dbc:mysql://localhost:3306/tickets

# Opcja dla pełnego środowiska Docker Compose (używa wewnętrznej nazwy serwisu `mysql`)
# MYSQL_URL_R2DBC=r2dbc:mysql://mysql:3306/tickets

MYSQL_DATABASE=tickets
MYSQL_USER=tickets
MYSQL_PASSWORD=tickets


# --- A.3. Redis (dla pamięci roboczej i zadań w tle) ---
# Wybierz jedną z opcji.

# Opcja dla środowiska hybrydowego LUB połączenia z Redis w chmurze
REDIS_URL=redis://default:your_password@your_redis_cloud_host:10303

# Opcja dla pełnego środowiska Docker Compose
# REDIS_URL=redis://redis:6379/0


# --- A.4. NATS (dla systemu zdarzeń i audytu) ---
# Wybierz jedną z opcji.

# Opcja dla środowiska hybrydowego
NATS_URL=nats://localhost:4222

# Opcja dla pełnego środowiska Docker Compose
# NATS_URL=nats://nats:4222


# --- A.5. Adresy URL Wewnętrznych Serwisów ---
# Jak serwisy mają się ze sobą komunikować.

# Opcja dla środowiska hybrydowego (Python lokalnie łączy się z Javą w Dockerze)
TICKETS_BASE_URL=http://localhost:8082

# Opcja dla pełnego środowiska Docker Compose
# TICKETS_BASE_URL=http://ticket-adapter:8081


# ------------------------------------------------------------------------------
# B. Konfiguracja Bezpieczeństwa (OIDC/JWT)
# ------------------------------------------------------------------------------
# Wymagane przez `api-gateway` (Python) i `ticket-adapter-java` do walidacji tokenów.

OIDC_ISSUER=https://your-keycloak-or-auth0-issuer.com/
OIDC_AUDIENCE=astradesk-api
OIDC_JWKS_URL=https://your-keycloak-or-auth0-issuer.com/.well-known/jwks.json


# ------------------------------------------------------------------------------
# C. Konfiguracja Zewnętrznych API (Narzędzia / Tools)
# ------------------------------------------------------------------------------

# --- C.1. Prometheus (dla narzędzia `get_metrics`) ---
# Adres API serwera Prometheus.

# Opcja dla środowiska hybrydowego (jeśli Prometheus działa w Dockerze)
MONITORING_API_URL=http://localhost:9090

# Opcja dla pełnego środowiska Docker Compose
# MONITORING_API_URL=http://prometheus:9090


# --- C.2. OpenWeatherMap (dla narzędzia `get_weather`) ---
# Zarejestruj się na openweathermap.org, aby uzyskać darmowy klucz.
WEATHER_API_KEY="your_openweathermap_api_key_here"


# ------------------------------------------------------------------------------
# D. Konfiguracja Modelu Językowego (LLM)
# ------------------------------------------------------------------------------
# Wybierz jednego z dostawców: "openai", "bedrock", "vllm".
MODEL_PROVIDER=openai

# --- D.1. OpenAI ---
OPENAI_API_KEY="sk-your_openai_api_key_here"
OPENAI_MODEL="gpt-4o-mini"
# OPENAI_BASE_URL="https://api.openai.com/v1" # Opcjonalnie, do użycia z proxy

# --- D.2. AWS Bedrock ---
# Wymaga skonfigurowanych poświadczeń AWS (np. przez `~/.aws/credentials` lub zmienne środowiskowe)
# AWS_REGION="eu-central-1"
# BEDROCK_MODEL_ID="anthropic.claude-3-sonnet-v1:0"

# --- D.3. vLLM (Self-hosted) ---
# VLLM_BASE_URL="http://localhost:8000/v1"
# VLLM_MODEL="meta-llama/Llama-3-8B-Instruct"


# ------------------------------------------------------------------------------
# E. Konfiguracja Poziomu Logowania
# ------------------------------------------------------------------------------
# Dostępne poziomy: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO


POLICY_JSON = "..."
POLICY_FILE = "... "
POLICY_TTL_SECONDS = "..."