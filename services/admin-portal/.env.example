# Admin Portal (Next.js) environment example. Copy to `.env.local` and adjust.
# Values here are placeholders only — never commit real backend URLs or tokens.

# Required by client-env validation (lib/env.ts). Validated at build time during
# static page-data collection and at runtime. CI sets a localhost placeholder for
# `next build`; provide the real admin API base URL in deployed environments.
NEXT_PUBLIC_API_BASE_URL=https://simulation.local

# When "true", the portal serves built-in simulation data instead of calling the API.
NEXT_PUBLIC_SIMULATION_MODE=true

# Optional server-side token for authenticated API calls.
ASTRADESK_API_TOKEN=dev-token

# Front-channel OIDC (ISSUE 021). All optional — unset means admin login is
# "unconfigured": the protected shell (everything except /login and
# /callback) redirects to /login and stays blocked, the same as an
# unauthenticated session (fail-closed). Ignored while
# NEXT_PUBLIC_SIMULATION_MODE=true.
#
# Works with any standards-compliant OIDC provider (Auth0, Keycloak, Okta,
# ...) via `.well-known/openid-configuration` discovery — no provider-specific
# SDK. Never put a client secret here: this is a public browser SPA client
# using Authorization Code + PKCE, so no secret is used or needed.
NEXT_PUBLIC_OIDC_ISSUER=
NEXT_PUBLIC_OIDC_CLIENT_ID=
# Set only if your Admin API access tokens require an explicit `audience`
# parameter at the authorization endpoint (e.g. Auth0-style APIs).
NEXT_PUBLIC_OIDC_AUDIENCE=
# Must exactly match a redirect URI registered with the identity provider,
# and must resolve to this portal's /callback route.
NEXT_PUBLIC_OIDC_REDIRECT_URI=http://localhost:3000/callback
# Space-separated OIDC scopes. Defaults to "openid profile email" if unset.
NEXT_PUBLIC_OIDC_SCOPE=
# Where the identity provider sends the browser after RP-initiated logout.
# Defaults to "<this origin>/login" if unset.
NEXT_PUBLIC_OIDC_POST_LOGOUT_REDIRECT_URI=
