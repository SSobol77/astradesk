# Python
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
*.whl

# Java
services/ticket-adapter-java/build/
services/ticket-adapter-java/.gradle/
services/ticket-adapter-java/gradle/wrapper/*.jar
*.class
*.jar
*.war
*.ear
# The Gradle wrapper JARs MUST be committed so `./gradlew` works in CI and on
# fresh clones. Re-include them despite the broad `*.jar` ignore above.
# (Negations must come AFTER `*.jar` — the last matching pattern wins.)
!gradle/wrapper/gradle-wrapper.jar
!services/ticket-adapter-java/gradle/wrapper/gradle-wrapper.jar
target/
astradesk.egg-info/
# Ignoruj pliki generowane przez IDE i systemy budowania
bin/
out/
*.class

# Node.js / Next.js
services/admin-portal/node_modules/
services/admin-portal/.next/
services/admin-portal/out/
services/admin-portal/build/
services/admin-portal/.env.local
services/admin-portal/.env.development.local
services/admin-portal/.env.test.local
services/admin-portal/.env.production.local

# npm and yarn debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# next.js
.next

# sveltekit
/.svelte-kit
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Docker
docker-compose.override.yml
*.dockerignore

# Environment variables
.env
*.env



# Terraform
infra/.terraform/
infra/.terraform.lock.hcl
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/*.tfstate
infra/*.tfstate.*

# Kubernetes / Helm
deploy/chart/templates/*.yaml.bak
deploy/chart/Chart.lock
deploy/chart/charts/
deploy/chart/tmpcharts/

# Istio
deploy/istio/*.bak
deploy/istio/*.tmp

# Ansible
ansible/inventories/*/*.retry
ansible/inventories/*/group_vars/*.bak
ansible/inventories/*/host_vars/*.bak

# Puppet
puppet/.tmp/
puppet/.bundle/
puppet/vendor/

# Salt
salt/.cache/
salt/.srv/

# Testing
coverage/
.coverage
*.cover
*.lcov
junit.xml
pytest_cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
test-results/
test-output/

# Logs
logs/
*.log
*.log.*
npm-debug.log*
yarn-error.log*
*.txt

# IDE and Editor Files
.idea/
*.iml
.vscode/
*.swp
*.swo
*~
*.txt
astradesk.code-workspace

# OS-specific files
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.backup

# Old version
_*.*
!mcp/__init__.py
!mcp/src/**/__init__.py
!packages/domain-support/src/**/__init__.py
!packages/domain-ops/src/**/__init__.py
!packages/domain-finance/src/**/__init__.py
!packages/domain-supply/src/**/__init__.py
!core/src/**/__init__.py
!services/api-gateway/src/**/__init__.py
!services/admin_api/src/**/__init__.py

# Build artifacts
*.tar.gz
*.zip

# Monitoring / Grafana
grafana/provisioning/
grafana/data/

# Miscellaneous
*.pid
*.seed
*.rdb
*.pid.lock
*.cache
*.db
*.sqlite3
# --- Java/Gradle build outputs ---
**/.gradle/
**/build/
**/bin/
**/out/
target/
.gradle/
build/

# Test artifacts
coverage.xml

